		{
			this.ammoPerWeight = DBConstantsID.instance.ammoAndWeaponManager.GetAmmoInfo(DBConstantsID.LookupPrefab(item.typeID, item.subID)).weightPerAmmo;
			this.calculatedWeight += (double)((float)item.resourcesLeft * this.ammoPerWeight);
		}
		if (item.category == SpawnTypes.WeaponsNonStack)
		{
			for (int i = 0; i < DBConstantsID.instance.ammoAndWeaponManager.weapons.Length; i++)
			{
				if (DBConstantsID.instance.ammoAndWeaponManager.settings.weapons[i].typeName == DBConstantsID.LookupPrefab(item.typeID, item.subID))
				{
					this.calculatedWeight += (double)((float)item.resourcesLeft * DBConstantsID.instance.ammoAndWeaponManager.weaponsAndAmmo[DBConstantsID.instance.ammoAndWeaponManager.settings.weapons[i].typeName].weightPerAmmo);
				}
			}
		}
		if (item.attachedObjectsAmount > 0)
		{
			for (int j = 0; j < item.attachedObjectsInfo.Length; j++)
			{
				if (item.attachedObjectsInfo[j] != null)
				{
					this.calculatedWeight += Math.Round(item.attachedObjectsInfo[j].weight, 2);
				}
			}
		}
		return Math.Round(this.calculatedWeight, 2);
	}

